ENVIRONMENT=development
DB_SOURCE=postgresql://pintour:pintour@localhost:5432/pintour_db?sslmode=disable
HTTP_SERVER_ADDRESS=0.0.0.0:8080
GRPC_SERVER_ADDRESS=0.0.0.0:8081
TOKEN_SYMMETRIC_KEY=your-32-char-secret-key-here-xxxx
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=24h
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/v1/auth/google/callback
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false
MIGRATION_URL=file://internal/db/migration
